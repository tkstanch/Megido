# Local Development Settings
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*
USE_SQLITE=true

# External Network Access
ALLOW_EXTERNAL_REQUESTS=true
VERIFY_SSL=false
REQUESTS_TIMEOUT=30

# Database (if using PostgreSQL)
DB_NAME=megido_db
DB_USER=megido_user
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# ngrok Configuration
# If running Megido behind ngrok or scanning ngrok URLs, set these:
# NGROK_URL=https://your-subdomain.ngrok-free.app
# Note: NGROK_URL is automatically added to CSRF_TRUSTED_ORIGINS

# ngrok Authentication Token (for callback verification)
# Get your token from: https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# Issue Tracker Integration
TRACKER_TYPE=none  # none, jira, bugzilla
JIRA_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=SEC
JIRA_EMAIL=scanner@your-org.com
JIRA_API_TOKEN=your-api-token
JIRA_ISSUE_TYPE=Bug
BUGZILLA_URL=https://bugzilla.your-org.com
BUGZILLA_API_KEY=your-api-key
BUGZILLA_PRODUCT=Security
BUGZILLA_COMPONENT=Vulnerabilities
TRACKER_AUTO_CREATE_CONFIRMED=true
TRACKER_AUTO_CREATE_FP=true
TRACKER_SYNC_INTERVAL=30
TRACKER_SEVERITY_THRESHOLD=medium

# XSS Callback Verification Configuration
# Callback endpoint for verifying XSS exploits
# Examples: https://burpcollaborator.net, https://interact.sh, https://your-webhook.com
XSS_CALLBACK_ENDPOINT=
# Timeout for waiting for callback (in seconds)
XSS_CALLBACK_TIMEOUT=30
# Enable callback verification (if false, uses traditional alert-based detection)
XSS_CALLBACK_VERIFICATION_ENABLED=true
